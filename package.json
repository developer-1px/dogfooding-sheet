{
  "name": "spredsheet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm --dir packages/grid build && pnpm --dir packages/formula build && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run && pnpm --dir packages/grid test && pnpm --dir packages/formula test",
    "check": "pnpm lint && pnpm build && pnpm test"
  },
  "dependencies": {
    "@interactive-os/anyeditable": "file:../editable/packages/anyeditable",
    "@interactive-os/aria-kernel": "file:../aria-kernel/packages/aria-kernel",
    "@interactive-os/devtools": "file:../devtools",
    "@interactive-os/document": "file:../document",
    "@interactive-os/editor": "file:../editor",
    "@interactive-os/keyboard": "file:../keyboard/packages/keyboard",
    "@interactive-os/keyboard-navigation": "file:../keyboard-navigation/packages/keyboard-navigation",
    "@interactive-os/playground-catalog": "file:../playground-catalog",
    "@spredsheet/formula": "workspace:*",
    "@spredsheet/grid": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.0.0",
    "zod-crud": "file:../zod-crud/packages/zod-crud"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "@interactive-os/document": "file:../document"
    }
  }
}
