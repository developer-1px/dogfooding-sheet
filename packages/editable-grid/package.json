{
  "name": "@spredsheet/editable-grid",
  "version": "0.0.0",
  "description": "Stable contract for schema-driven editable grid islands.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cell-display": {
      "development": "./src/cellDisplay.ts",
      "types": "./dist/cellDisplay.d.ts",
      "import": "./dist/cellDisplay.js"
    },
    "./contract": {
      "development": "./src/contract.ts",
      "types": "./dist/contract.d.ts",
      "import": "./dist/contract.js"
    },
    "./primitives": {
      "development": "./src/primitives.ts",
      "types": "./dist/primitives.d.ts",
      "import": "./dist/primitives.js"
    },
    "./resize-rules": {
      "development": "./src/resizeRules.ts",
      "types": "./dist/resizeRules.d.ts",
      "import": "./dist/resizeRules.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "zod": "^4.0.0"
  },
  "dependencies": {
    "@spredsheet/grid": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "~6.0.2",
    "vitest": "^4.1.5"
  }
}
