{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@aria/engine": ["./src/interactive-os/devtoolsARIAShims.ts"],
      "@aria/primitives": ["./src/interactive-os/devtoolsARIAShims.ts"],
      "@interactive-os/playground-catalog": ["../playground-catalog/src/index.d.mts"],
      "@spredsheet/editable-grid/cell-display": ["./packages/editable-grid/src/cellDisplay.ts"],
      "@spredsheet/editable-grid/contract": ["./packages/editable-grid/src/contract.ts"],
      "@spredsheet/editable-grid/resize-rules": ["./packages/editable-grid/src/resizeRules.ts"],
      "@spredsheet/editable-grid": ["./packages/editable-grid/src/index.ts"],
      "@spredsheet/formula": ["./packages/formula/src/index.ts"],
      "@spredsheet/grid": ["./packages/grid/src/index.ts"],
      "@spredsheet/surface": ["./packages/surface/src/index.ts"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
